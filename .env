
# ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# Basic parameters
# ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

APP_ENV=dev
APP_SECRET=

# ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# SQL Database parameters
# ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url

# DATABASE_URL="sqlite:///%kernel.project_dir%/var/database.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
# DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"

# ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# MongoDB parameters
# ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

# Format described at https://www.mongodb.com/docs/php-library/current/connect/connection-options/

# MONGODB_URL="mongodb://username:password@localhost:27017/?authSource=auth-db"
# MONGODB_URL="mongodb+srv://username:password@YOUR_CLUSTER_NAME.YOUR_HASH.mongodb.net/?retryWrites=true&w=majority"

# ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# Message Bus parameters
# ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# Email parameters
# ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

MAILER_DSN=null://null

# ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# Http parameters
# ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

# ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# Console style parameters
# ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

APP_CONSOLE_STYLE_SECTION_SEPARATOR_CHAR=+
APP_CONSOLE_STYLE_SECTION_SEPARATOR_LENGTH=80
APP_CONSOLE_STYLE_CVE_TABLE_NAME_LENGTH_MAX=22
APP_CONSOLE_STYLE_CVE_TABLE_VALUE_LENGTH_MAX=40
